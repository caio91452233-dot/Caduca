<!DOCTYPE html><html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Desafio Histórico</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Cinzel', serif;
      background: url('https://images.unsplash.com/photo-1524995997946-a1c2e315a42f') no-repeat center/cover;
      color: #f5f5dc;
      text-align: center;
      padding: 20px;
    }.overlay {
  background: rgba(0, 0, 0, 0.7);
  min-height: 100vh;
  padding: 30px;
}

.quiz-box {
  background: rgba(20, 20, 30, 0.9);
  padding: 25px;
  border-radius: 15px;
  max-width: 700px;
  margin: auto;
  box-shadow: 0 0 20px rgba(0,0,0,0.8);
}

h1 { margin-bottom: 10px; }

#topbar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
  font-size: 14px;
  color: #ccc;
}

#timer {
  font-weight: bold;
  color: #ffd700;
}

button {
  display: block;
  width: 100%;
  margin: 10px 0;
  padding: 12px;
  border: none;
  border-radius: 10px;
  background: #8b0000;
  color: white;
  cursor: pointer;
  font-size: 16px;
  transition: 0.3s;
}

button:hover { background: #a52a2a; }

button:disabled { background: gray; cursor: not-allowed; }

#nextBtn { background: #444; }

  </style>
</head>
<body><div class="overlay">
  <h1>📜 Desafio Histórico</h1>  <div class="quiz-box">
    <div id="topbar">
      <span id="progress"></span>
      <span>⏱️ Tempo: <span id="timer">15</span>s</span>
    </div><h2 id="question"></h2>
<div id="answers"></div>
<p id="feedback"></p>
<button id="nextBtn" onclick="nextQuestion()" disabled>Próxima</button>

  </div>
</div><script>
  let currentQuestion = 0;
  let score = 0;
  let answered = false;
  let timeLeft = 15;
  let timerInterval;

  const questions = [
    {
      question: "O que fez a guerra se expandir rapidamente?",
      answers: ["Acordos de paz", "Alianças entre países", "Falta de exércitos", "Comércio internacional"],
      correct: 1
    },
    {
      question: "Por que a Alemanha declarou guerra à França?",
      answers: ["Para defender a Inglaterra", "Para evitar lutar em duas frentes", "Por causa de um tratado de paz", "Para ajudar a Rússia"],
      correct: 1
    },
    {
      question: "O que foi o Plano Schlieffen?",
      answers: ["Um acordo de paz", "Um plano para atacar a Rússia", "Um plano para derrotar a França rapidamente", "Um tratado entre países"],
      correct: 2
    },
    {
      question: "Por que a Inglaterra entrou na guerra?",
      answers: ["Por causa da invasão da Bélgica", "Para ajudar a Alemanha", "Para conquistar a Rússia", "Por interesses na Ásia"],
      correct: 0
    },
    {
      question: "Por que a Itália mudou de lado?",
      answers: ["Porque perdeu a guerra", "Por promessas de territórios", "Por amizade com a Alemanha", "Por pressão dos EUA"],
      correct: 1
    },
    {
      question: "Por que a guerra ficou parada em trincheiras?",
      answers: ["Falta de soldados", "Dificuldade de avançar", "Falta de armas", "Acordos de paz"],
      correct: 1
    },
    {
      question: "O que mudou com a entrada dos Estados Unidos na guerra?",
      answers: ["A guerra acabou na hora", "A Alemanha venceu", "A Tríplice Entente ganhou força", "A Rússia voltou à guerra"],
      correct: 2
    },
    {
      question: "Por que os EUA entraram na guerra?",
      answers: ["Para ajudar a Alemanha", "Por interesses econômicos e políticos", "Por amizade com a Rússia", "Por falta de recursos"],
      correct: 1
    },
    {
      question: "O que foi a Revolução Russa?",
      answers: ["Uma guerra contra a Alemanha", "Um acordo de paz", "Uma mudança de governo na Rússia", "Um tratado internacional"],
      correct: 2
    },
    {
      question: "Por que a saída da Rússia ajudou a Alemanha?",
      answers: ["Porque acabou a guerra", "Porque liberou tropas para outro front", "Porque a Rússia venceu", "Porque os EUA saíram"],
      correct: 1
    }
  ];

  function startTimer() {
    timeLeft = 15;
    document.getElementById("timer").innerText = timeLeft;

    timerInterval = setInterval(() => {
      timeLeft--;
      document.getElementById("timer").innerText = timeLeft;

      if (timeLeft <= 0) {
        clearInterval(timerInterval);
        autoFail();
      }
    }, 1000);
  }

  function loadQuestion() {
    answered = false;
    const q = questions[currentQuestion];

    document.getElementById("question").innerText = q.question;
    document.getElementById("progress").innerText = `Pergunta ${currentQuestion + 1} de ${questions.length}`;

    const answersDiv = document.getElementById("answers");
    answersDiv.innerHTML = "";

    q.answers.forEach((answer, index) => {
      const btn = document.createElement("button");
      btn.innerText = answer;
      btn.onclick = () => checkAnswer(btn, index);
      answersDiv.appendChild(btn);
    });

    document.getElementById("feedback").innerText = "";
    document.getElementById("nextBtn").disabled = true;

    startTimer();
  }

  function checkAnswer(button, index) {
    if (answered) return;

    answered = true;
    clearInterval(timerInterval);

    const correct = questions[currentQuestion].correct;
    const buttons = document.querySelectorAll("#answers button");

    buttons.forEach((btn, i) => {
      btn.disabled = true;
      if (i === correct) btn.style.background = "green";
      if (i === index && i !== correct) btn.style.background = "darkred";
    });

    if (index === correct) {
      document.getElementById("feedback").innerText = "✔️ Correto!";
      score += 10;
    } else {
      document.getElementById("feedback").innerText = "❌ Errado!";
    }

    document.getElementById("nextBtn").disabled = false;
  }

  function autoFail() {
    if (answered) return;

    answered = true;

    const correct = questions[currentQuestion].correct;
    const buttons = document.querySelectorAll("#answers button");

    buttons.forEach((btn, i) => {
      btn.disabled = true;
      if (i === correct) btn.style.background = "green";
    });

    document.getElementById("feedback").innerText = "⏱️ Tempo esgotado!";
    document.getElementById("nextBtn").disabled = false;
  }

  function nextQuestion() {
    currentQuestion++;

    if (currentQuestion < questions.length) {
      loadQuestion();
    } else {
      showResult();
    }
  }

  function showResult() {
    let rank = "";

    if (score <= 20) rank = "Iniciante";
    else if (score <= 40) rank = "Aprendiz";
    else if (score <= 60) rank = "Historiador";
    else rank = "Mestre da História 👑";

    document.querySelector(".quiz-box").innerHTML = `
      <h2>🏆 Resultado Final</h2>
      <p>Pontuação: ${score}</p>
      <p>Classificação: ${rank}</p>
    `;
  }

  loadQuestion();
</script></body>
</html>